generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum RequirementStatus {
  DRAFT
  READY
  NEEDS_CLARIFICATION
}

enum AnalysisStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum TaskType {
  FRONTEND
  BACKEND
  QA
  DEVOPS
  DESIGN
  DOCUMENTATION
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model User {
  id             String            @id @default(uuid())
  name           String
  email          String            @unique
  passwordHash   String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  memberships    WorkspaceMember[]
  refreshTokens  RefreshToken[]
  requirements   Requirement[]     @relation("RequirementCreator")
  requirementVersions RequirementVersion[] @relation("RequirementVersionCreator")
  tasksCreated   Task[]            @relation("TaskCreator")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Workspace {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships WorkspaceMember[]
  projects    Project[]
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Project {
  id           String        @id @default(uuid())
  workspaceId  String
  name         String
  key          String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requirements Requirement[]
  tasks         Task[]
  sprints       Sprint[]

  @@unique([workspaceId, key])
  @@index([workspaceId, status])
}

model Requirement {
  id             String            @id @default(uuid())
  projectId      String
  createdById    String
  title          String
  currentContent String
  status         RequirementStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy      User              @relation("RequirementCreator", fields: [createdById], references: [id])
  versions       RequirementVersion[]
  analyses       AIAnalysis[]
  tasks          Task[]

  @@index([projectId, status])
}

model RequirementVersion {
  id            String       @id @default(uuid())
  requirementId String
  createdById   String
  versionNumber Int
  content       String
  createdAt     DateTime     @default(now())
  requirement   Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  createdBy     User         @relation("RequirementVersionCreator", fields: [createdById], references: [id])
  analyses      AIAnalysis[]

  @@unique([requirementId, versionNumber])
  @@index([requirementId, createdAt])
}

model AIAnalysis {
  id                        String         @id @default(uuid())
  requirementId             String
  requirementVersionId      String
  provider                  String
  model                     String
  status                    AnalysisStatus @default(PROCESSING)
  clarificationQuestions    Json?
  functionalRequirements    Json?
  nonFunctionalRequirements Json?
  userStories               Json?
  technicalPlan             Json?
  risks                     Json?
  rawOutput                 Json?
  errorMessage              String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  requirement               Requirement    @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  requirementVersion        RequirementVersion @relation(fields: [requirementVersionId], references: [id], onDelete: Cascade)
  tasks                     Task[]

  @@index([requirementId, createdAt])
  @@index([requirementVersionId, status])
}

model Task {
  id                 String       @id @default(uuid())
  projectId          String
  requirementId      String?
  analysisId         String?
  sprintId           String?
  createdById        String
  title              String
  description        String
  type               TaskType
  priority           TaskPriority @default(MEDIUM)
  status             TaskStatus   @default(BACKLOG)
  storyPoints        Int?
  acceptanceCriteria Json?
  labels             String[]     @default([])
  position           Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement        Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  analysis           AIAnalysis?  @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  sprint             Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  createdBy          User         @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([projectId, status])
  @@index([analysisId])
  @@index([sprintId])
}

model Sprint {
  id             String       @id @default(uuid())
  projectId      String
  name           String
  goal           String?
  status         SprintStatus @default(PLANNED)
  startDate      DateTime?
  endDate        DateTime?
  capacityPoints Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@unique([projectId, name])
  @@index([projectId, status])
}
